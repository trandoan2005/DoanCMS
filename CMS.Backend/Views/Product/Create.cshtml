@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Thêm Sản phẩm";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Thêm Sản phẩm mới</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryProductId" class="form-label fw-semibold">Danh mục sản phẩm <span class="text-danger">*</span></label>
                            <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductId">
                                <option value="">-- Chọn danh mục sản phẩm --</option>
                            </select>
                            <span asp-validation-for="CategoryProductId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label fw-semibold">Giá bán (₫) <span class="text-danger">*</span></label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="Ví dụ: 150000" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="StockQuantity" class="form-label fw-semibold">Số lượng trong kho <span class="text-danger">*</span></label>
                            <input asp-for="StockQuantity" class="form-control" type="number" placeholder="Ví dụ: 50" />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-semibold">Đường dẫn ảnh sản phẩm</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">Mô tả sản phẩm</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập chi tiết về sản phẩm..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save me-1"></i> Lưu
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
