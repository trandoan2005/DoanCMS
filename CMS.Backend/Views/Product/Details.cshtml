@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Chi tiết Sản phẩm";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Chi tiết Sản phẩm</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border shadow-sm" style="max-height: 250px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center border rounded shadow-sm" style="height: 200px; font-size: 14px;">Không có ảnh</div>
                        }
                    </div>
                    <div class="col-md-8">
                        <dl class="row">
                            <dt class="col-sm-4 fw-semibold">ID sản phẩm</dt>
                            <dd class="col-sm-8">@Model.Id</dd>

                            <dt class="col-sm-4 fw-semibold">Tên sản phẩm</dt>
                            <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                            <dt class="col-sm-4 fw-semibold">Danh mục</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-secondary">@(Model.CategoryProduct?.Name ?? "N/A")</span>
                            </dd>

                            <dt class="col-sm-4 fw-semibold">Giá bán</dt>
                            <dd class="col-sm-8 text-danger fw-semibold">@Model.Price.ToString("N0") ₫</dd>

                            <dt class="col-sm-4 fw-semibold">Số lượng kho</dt>
                            <dd class="col-sm-8">
                                @if (Model.StockQuantity > 0)
                                {
                                    <span class="badge bg-success">@Model.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </dd>

                            <dt class="col-sm-4 fw-semibold">Mô tả sản phẩm</dt>
                            <dd class="col-sm-8">@(Model.Description ?? "Không có mô tả chi tiết")</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>
