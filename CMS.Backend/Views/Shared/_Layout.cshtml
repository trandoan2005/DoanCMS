<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DoanCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0f1117;
            color: #e2e8f0;
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: #1a1d2e;
            border-right: 1px solid rgba(255,255,255,0.06);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            color: white;
        }

        .brand-text {
            font-size: 18px;
            font-weight: 700;
            color: white;
        }

        .brand-sub {
            font-size: 11px;
            color: rgba(255,255,255,0.4);
            margin-top: 2px;
        }

        .sidebar-section {
            padding: 20px 12px 8px;
            font-size: 10px;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
        }

        .nav-item-custom {
            margin: 2px 8px;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 16px;
            border-radius: 10px;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
        }

            .nav-link-custom:hover {
                background: rgba(255,255,255,0.07);
                color: white;
            }

            .nav-link-custom.active {
                background: linear-gradient(135deg, rgba(99,102,241,0.3), rgba(139,92,246,0.2));
                color: white;
                border: 1px solid rgba(99,102,241,0.3);
            }

            .nav-link-custom i {
                font-size: 17px;
                width: 20px;
                text-align: center;
            }

        .sidebar-footer {
            margin-top: auto;
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 12px;
            background: rgba(255,255,255,0.05);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6366f1, #ec4899);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: white;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: white;
        }

        .user-role {
            font-size: 11px;
            color: rgba(255,255,255,0.4);
        }

        /* MAIN */
        .main-wrapper {
            margin-left: 260px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background: rgba(26,29,46,0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .page-title {
            font-size: 20px;
            font-weight: 700;
            color: white;
        }

        .page-sub {
            font-size: 13px;
            color: rgba(255,255,255,0.4);
            margin-top: 2px;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 13px;
            background: rgba(239,68,68,0.15);
            color: #f87171;
            border: 1px solid rgba(239,68,68,0.2);
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-logout:hover {
                background: rgba(239,68,68,0.25);
                color: #fca5a5;
            }

        .content-area {
            padding: 32px;
            flex: 1;
        }

        /* CARDS */
        .glass-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 24px;
        }

        .card {
            background: #1a1d2e !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            color: #e2e8f0 !important;
        }

        .card-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
        }

        .card-footer {
            border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
            background: rgba(0, 0, 0, 0.15) !important;
        }

        /* TABLES & LISTS DARK OVERRIDES */
        .table {
            color: #e2e8f0 !important;
            --bs-table-bg: transparent !important;
            border-color: rgba(255, 255, 255, 0.08) !important;
        }

        .table-striped tbody tr:nth-of-type(odd) td {
            background-color: rgba(255, 255, 255, 0.015) !important;
            color: #e2e8f0 !important;
        }

        .table-hover tbody tr:hover td {
            background-color: rgba(255, 255, 255, 0.035) !important;
            color: #ffffff !important;
        }

        .list-group-item {
            background-color: transparent !important;
            color: #e2e8f0 !important;
            border-color: rgba(255, 255, 255, 0.08) !important;
        }

        .stat-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 20px 24px;
            transition: all 0.3s;
        }

            .stat-card:hover {
                background: rgba(255,255,255,0.07);
                transform: translateY(-2px);
            }

        .stat-number {
            font-size: 32px;
            font-weight: 700;
            color: white;
        }

        .stat-label {
            font-size: 13px;
            color: rgba(255,255,255,0.5);
            margin-top: 4px;
        }

        .stat-icon {
            font-size: 24px;
            margin-bottom: 12px;
        }

        /* TABLE */
        .table-dark-custom {
            background: transparent;
        }

            .table-dark-custom thead th {
                background: rgba(255,255,255,0.05);
                color: rgba(255,255,255,0.6);
                font-size: 12px;
                letter-spacing: 1px;
                text-transform: uppercase;
                border: none;
                padding: 14px 16px;
            }

            .table-dark-custom tbody td {
                border-color: rgba(255,255,255,0.05);
                color: rgba(255,255,255,0.8);
                padding: 14px 16px;
                vertical-align: middle;
            }

            .table-dark-custom tbody tr:hover td {
                background: rgba(255,255,255,0.03);
            }

        .badge-custom {
            padding: 5px 12px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
        }

        /* BUTTONS */
        .btn-primary-custom {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border: none;
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

            .btn-primary-custom:hover {
                opacity: 0.85;
                transform: translateY(-1px);
                color: white;
            }

        /* FORM */
        .form-control, .form-select {
            background: rgba(255,255,255,0.06) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            color: white !important;
            border-radius: 10px !important;
            padding: 12px 16px !important;
        }

            .form-control:focus, .form-select:focus {
                background: rgba(255,255,255,0.09) !important;
                border-color: rgba(99,102,241,0.5) !important;
                box-shadow: 0 0 0 3px rgba(99,102,241,0.15) !important;
            }

            .form-control::placeholder {
                color: rgba(255,255,255,0.3) !important;
            }

        .form-label {
            color: rgba(255,255,255,0.7);
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .form-select option {
            background: #1a1d2e;
        }

        /* ALERT */
        .alert-success-custom {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.2);
            color: #86efac;
            border-radius: 10px;
            padding: 12px 16px;
        }

        .alert-danger-custom {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2);
            color: #fca5a5;
            border-radius: 10px;
            padding: 12px 16px;
        }

        .scrollbar-hide {
            scrollbar-width: none;
        }

            .scrollbar-hide::-webkit-scrollbar {
                display: none;
            }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar scrollbar-hide">
        <div class="sidebar-brand">
            <div class="brand-icon">D</div>
            <div>
                <div class="brand-text">DoanCMS</div>
                <div class="brand-sub">Admin Panel</div>
            </div>
        </div>

        <div class="sidebar-section">Tổng quan</div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid-fill"></i> Dashboard
            </a>
        </div>

        <div class="sidebar-section">Quản lý nội dung</div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
               asp-controller="Category" asp-action="Index">
                <i class="bi bi-tags-fill"></i> Danh mục
            </a>
        </div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Post" ? "active" : "")"
               asp-controller="Post" asp-action="Index">
                <i class="bi bi-file-earmark-text-fill"></i> Bài viết
            </a>
        </div>

        <div class="sidebar-section">Quản lý bán hàng</div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "CategoryProduct" ? "active" : "")"
               asp-controller="CategoryProduct" asp-action="Index">
                <i class="bi bi-tags"></i> Danh mục SP
            </a>
        </div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
               asp-controller="Product" asp-action="Index">
                <i class="bi bi-box-seam"></i> Sản phẩm
            </a>
        </div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"
               asp-controller="Order" asp-action="Index">
                <i class="bi bi-cart-check-fill"></i> Đơn hàng
            </a>
        </div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"
               asp-controller="Customer" asp-action="Index">
                <i class="bi bi-people-fill"></i> Khách hàng
            </a>
        </div>

        <div class="sidebar-section">Hệ thống</div>
        <div class="nav-item-custom">
            <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "")"
               asp-controller="Account" asp-action="Login">
                <i class="bi bi-shield-lock-fill"></i> Bảo mật
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">TD</div>
                <div>
                    <div class="user-name">Trần Văn Đoàn</div>
                    <div class="user-role">CCQ2311F · 2123110210</div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main-wrapper">
        <div class="topbar">
            <div>
                <div class="page-title">@(ViewData["Title"] ?? "Dashboard")</div>
                <div class="page-sub">DoanCMS Admin Panel · Cao Đẳng Công Thương TPHCM</div>
            </div>
            <div class="topbar-actions">
                <a href="http://localhost:3000" target="_blank" class="btn-logout" style="background:rgba(99,102,241,0.15);color:#a5b4fc;border-color:rgba(99,102,241,0.2);">
                    <i class="bi bi-box-arrow-up-right"></i> Xem Frontend
                </a>
                <a asp-controller="Account" asp-action="Logout" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert-success-custom mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                </div>
            }
            @RenderBody()
        </div>

        <footer style="padding:16px 32px;border-top:1px solid rgba(255,255,255,0.06);color:rgba(255,255,255,0.25);font-size:12px;">
            © 2026 DoanCMS · Trần Văn Đoàn · Cao Đẳng Công Thương TPHCM
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>