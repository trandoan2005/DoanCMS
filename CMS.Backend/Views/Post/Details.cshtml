@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Chi tiết Bài viết";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Chi tiết Bài viết</h5>
                <span class="badge bg-white text-info">@(Model.Category?.Name ?? "N/A")</span>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-4 text-center">
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow-sm" style="max-height:300px; object-fit:cover;" />
                    </div>
                }

                <dl class="row">
                    <dt class="col-sm-3 fw-semibold">ID</dt>
                    <dd class="col-sm-9">@Model.Id</dd>

                    <dt class="col-sm-3 fw-semibold">Tiêu đề</dt>
                    <dd class="col-sm-9"><strong>@Model.Title</strong></dd>

                    <dt class="col-sm-3 fw-semibold">Danh mục</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary fs-6">@(Model.Category?.Name ?? "Không có")</span>
                    </dd>

                    <dt class="col-sm-3 fw-semibold">Ngày tạo</dt>
                    <dd class="col-sm-9">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                </dl>

                <hr />
                <h6 class="fw-bold text-muted mb-3">Nội dung bài viết:</h6>
                <div class="p-3 bg-light rounded">
                    @Model.Content
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>
