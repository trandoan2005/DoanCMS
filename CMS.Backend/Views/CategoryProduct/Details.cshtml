@model CMS.Data.Entities.CategoryProduct

@{
    ViewData["Title"] = "Chi tiết Danh mục sản phẩm";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Chi tiết Danh mục sản phẩm</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3 fw-semibold">ID</dt>
                    <dd class="col-sm-9">@Model.Id</dd>

                    <dt class="col-sm-3 fw-semibold">Tên danh mục</dt>
                    <dd class="col-sm-9"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-3 fw-semibold">Mô tả</dt>
                    <dd class="col-sm-9">@(Model.Description ?? "Không có mô tả")</dd>

                    <dt class="col-sm-3 fw-semibold">Số sản phẩm</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-primary fs-6">@(Model.Products?.Count ?? 0) sản phẩm</span>
                    </dd>
                </dl>

                @if (Model.Products != null && Model.Products.Any())
                {
                    <hr />
                    <h6 class="fw-bold text-muted mb-3">Sản phẩm thuộc danh mục:</h6>
                    <ul class="list-group list-group-flush">
                        @foreach (var prod in Model.Products)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-box me-2 text-primary"></i>@prod.Name
                                </div>
                                <span class="badge bg-secondary">@prod.Price.ToString("N0") ₫</span>
                            </li>
                        }
                    </ul>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>
