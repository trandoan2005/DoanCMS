@model CMS.Data.Entities.Order
@{
    ViewData["Title"] = $"Chi tiết đơn #{Model.Id}";
    var total = Model.OrderDetails?.Sum(od => od.Quantity * od.UnitPrice) ?? 0;

    string StatusLabel(int s) => s switch { 0 => "⏳ Chờ xử lý", 1 => "🚚 Đang giao", 2 => "✅ Đã giao", _ => "Không rõ" };
    string StatusClass(int s) => s switch { 0 => "pending", 1 => "shipping", 2 => "done", _ => "" };
}

<style>
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    @@media(max-width:768px) { .detail-grid { grid-template-columns: 1fr; } }

    .info-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px; padding: 20px;
    }
    .info-title { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 14px; }
    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .info-row:last-child { border-bottom: none; }
    .info-key { font-size: 13px; color: rgba(255,255,255,0.45); }
    .info-val { font-size: 14px; color: white; font-weight: 500; }

    .badge-status { display: inline-flex; align-items: center; gap: 5px; padding: 6px 14px; border-radius: 100px; font-size: 13px; font-weight: 600; }
    .badge-status.pending { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
    .badge-status.shipping { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }
    .badge-status.done { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }

    .product-row { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .product-row:last-child { border-bottom: none; }
    .product-img { width: 52px; height: 52px; border-radius: 10px; object-fit: cover; background: rgba(255,255,255,0.06); }
    .product-img-placeholder { width: 52px; height: 52px; border-radius: 10px; background: rgba(99,102,241,0.15); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .product-name { font-weight: 600; color: white; font-size: 14px; }
    .product-cat { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 2px; }
    .product-price { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 3px; }
    .product-qty { font-size: 13px; color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.06); padding: 3px 10px; border-radius: 20px; flex-shrink: 0; }
    .product-subtotal { font-weight: 700; color: #4ade80; font-size: 14px; flex-shrink: 0; min-width: 100px; text-align: right; }
    .product-info { flex: 1; min-width: 0; }

    .total-bar {
        display: flex; justify-content: space-between; align-items: center;
        padding: 16px 0 0; margin-top: 8px; border-top: 1px solid rgba(255,255,255,0.1);
    }
    .total-label { color: rgba(255,255,255,0.6); font-size: 14px; }
    .total-amount { font-size: 22px; font-weight: 800; color: #4ade80; }

    .status-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
    .btn-status {
        flex: 1; min-width: 120px; padding: 11px 16px; border-radius: 10px; border: none;
        font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; text-align: center;
    }
    .btn-pending { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
    .btn-pending:hover { background: rgba(251,191,36,0.25); }
    .btn-shipping { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }
    .btn-shipping:hover { background: rgba(59,130,246,0.25); }
    .btn-done { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
    .btn-done:hover { background: rgba(34,197,94,0.25); }
    .btn-active { opacity: 0.4; cursor: default; pointer-events: none; }

    .back-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 9px 18px; border-radius: 9px; font-size: 13px; font-weight: 500;
        background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7);
        border: 1px solid rgba(255,255,255,0.1); text-decoration: none; transition: all 0.2s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.1); color: white; }

    .delete-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 9px 18px; border-radius: 9px; font-size: 13px; font-weight: 500;
        background: rgba(239,68,68,0.1); color: #f87171;
        border: 1px solid rgba(239,68,68,0.2); text-decoration: none; transition: all 0.2s; cursor: pointer;
    }
    .delete-btn:hover { background: rgba(239,68,68,0.2); }
</style>

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="mb-1" style="color:white; font-weight:700;">📋 Chi tiết đơn hàng #@Model.Id</h4>
        <div class="page-sub">Đặt lúc @Model.OrderDate.ToString("HH:mm - dd/MM/yyyy")</div>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Index")" class="back-btn"><i class="bi bi-arrow-left"></i> Danh sách</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Xóa đơn hàng này?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="delete-btn"><i class="bi bi-trash"></i> Xóa đơn</button>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom mb-4">✅ @TempData["Success"]</div>
}

<div class="detail-grid">
    <!-- Thông tin khách hàng -->
    <div class="info-card">
        <div class="info-title">👤 Thông tin khách hàng</div>
        <div class="info-row">
            <span class="info-key">Họ tên</span>
            <span class="info-val">@(Model.Customer?.FullName ?? "N/A")</span>
        </div>
        <div class="info-row">
            <span class="info-key">Email</span>
            <span class="info-val">@(Model.Customer?.Email ?? "N/A")</span>
        </div>
        <div class="info-row">
            <span class="info-key">Điện thoại</span>
            <span class="info-val">@(Model.Customer?.Phone ?? "Chưa có")</span>
        </div>
        <div class="info-row">
            <span class="info-key">Địa chỉ</span>
            <span class="info-val">@(Model.Customer?.Address ?? "Chưa có")</span>
        </div>
    </div>

    <!-- Trạng thái đơn hàng -->
    <div class="info-card">
        <div class="info-title">📦 Trạng thái đơn hàng</div>
        <div class="mb-3">
            <span class="badge-status @StatusClass(Model.Status)">@StatusLabel(Model.Status)</span>
        </div>
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="info-row">
                <span class="info-key">Ghi chú</span>
                <span class="info-val">@Model.Notes</span>
            </div>
        }
        <div class="info-title mt-3">Chuyển trạng thái</div>
        <div class="status-actions">
            <form asp-action="ChangeStatus" method="post" style="flex:1; min-width:110px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="newStatus" value="0" />
                <button type="submit" class="btn-status btn-pending w-100 @(Model.Status == 0 ? "btn-active" : "")">⏳ Chờ xử lý</button>
            </form>
            <form asp-action="ChangeStatus" method="post" style="flex:1; min-width:110px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="newStatus" value="1" />
                <button type="submit" class="btn-status btn-shipping w-100 @(Model.Status == 1 ? "btn-active" : "")">🚚 Đang giao</button>
            </form>
            <form asp-action="ChangeStatus" method="post" style="flex:1; min-width:110px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="newStatus" value="2" />
                <button type="submit" class="btn-status btn-done w-100 @(Model.Status == 2 ? "btn-active" : "")">✅ Đã giao</button>
            </form>
        </div>
    </div>
</div>

<!-- Chi tiết sản phẩm -->
<div class="glass-card">
    <div class="info-title">🛍️ Sản phẩm trong đơn (@(Model.OrderDetails?.Count ?? 0) loại)</div>
    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
    {
        foreach (var item in Model.OrderDetails)
        {
            <div class="product-row">
                @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                {
                    <img src="@item.Product.ImageUrl" class="product-img" alt="@item.Product.Name" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                    <div class="product-img-placeholder" style="display:none;">🛍️</div>
                }
                else
                {
                    <div class="product-img-placeholder">🛍️</div>
                }
                <div class="product-info">
                    <div class="product-name">@(item.Product?.Name ?? "Sản phẩm đã xóa")</div>
                    <div class="product-cat">@(item.Product?.CategoryProduct?.Name ?? "")</div>
                    <div class="product-price">Đơn giá: @item.UnitPrice.ToString("N0")₫</div>
                </div>
                <span class="product-qty">x@item.Quantity</span>
                <span class="product-subtotal">@((item.Quantity * item.UnitPrice).ToString("N0"))₫</span>
            </div>
        }
        <div class="total-bar">
            <span class="total-label">Tổng cộng (@(Model.OrderDetails.Sum(od => od.Quantity)) sản phẩm)</span>
            <span class="total-amount">@total.ToString("N0")₫</span>
        </div>
    }
    else
    {
        <div style="text-align:center; padding:30px; color:rgba(255,255,255,0.3);">Không có sản phẩm nào</div>
    }
</div>
