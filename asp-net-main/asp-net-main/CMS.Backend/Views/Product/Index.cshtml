@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container mt-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold text-uppercase">
            Danh sách sản phẩm
        </h2>

        <p class="text-muted">
            Tổng cộng @(Model?.Count() ?? 0) sản phẩm
        </p>

    </div>

    <div class="row">

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card product-card shadow border-0 h-100 rounded-4">

                        <!-- IMAGE -->
                        <div class="overflow-hidden rounded-top-4"
                             style="height:250px;">

                            <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                         ? "https://via.placeholder.com/400x250?text=No+Image"
                                                                         : item.ImageUrl)"
                         class="w-100 h-100 product-img"
                         style="object-fit:cover;"
                         alt="@item.Name" />

                        </div>

                        <!-- BODY -->
                        <div class="card-body p-4">

                            <h4 class="fw-bold mb-3">
                                @item.Name
                            </h4>

                            <p class="text-muted small">
                                @item.Description
                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-4">

                                <span class="price-tag">
                                    @item.Price.ToString("N0") ₫
                                </span>

                                <span class="badge bg-primary">
                                    Kho: @item.StockQuantity
                                </span>

                            </div>

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">

                            <button class="btn btn-dark w-100 rounded-pill">
                                <i class="bi bi-cart-plus me-2"></i>
                                Xem sản phẩm
                            </button>

                        </div>

                    </div>

                </div>
                }
        }
        else
        {
            <div class="col-12 text-center py-5">

                <i class="bi bi-box-seam display-1 text-muted"></i>

                <h4 class="mt-3 text-muted">
                    Chưa có sản phẩm nào
                </h4>

            </div>
        }

    </div>

</div>

<style>

    body {
        background: #f8f9fc;
    }

    .product-card {
        transition: all 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
        }

    .product-img {
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.08);
    }

    .price-tag {
        color: #e74a3b;
        font-size: 20px;
        font-weight: bold;
    }

    .btn-dark {
        background: #2c3e50;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-dark:hover {
            background: #4e73df;
        }

</style>