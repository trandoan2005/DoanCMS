@model IEnumerable<CMS.Data.Entities.OrderDetail>

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5">

    <div class="detail-card shadow-lg border-0">

        <!-- HEADER -->
        <div class="header-custom">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <div>

                    <h2 class="text-white fw-bold mb-1">
                        <i class="fas fa-file-invoice-dollar me-2"></i>
                        Chi tiết đơn hàng
                    </h2>

                    <small class="text-white-50">
                        Tổng cộng @(Model?.Count() ?? 0) chi tiết
                    </small>

                </div>

            </div>

        </div>

        <!-- TABLE -->
        <div class="table-responsive p-4">

            <table class="table table-hover align-middle custom-table">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Order ID</th>
                        <th>Product ID</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var total = item.Quantity * item.UnitPrice;

                            <tr>

                                <td class="fw-bold text-muted">
                                    #@item.Id
                                </td>

                                <td>
                                    ORD-@item.OrderId
                                </td>

                                <td>
                                    PRD-@item.ProductId
                                </td>

                                <td>
                                    @item.Quantity
                                </td>

                                <td class="text-primary fw-bold">
                                    @item.UnitPrice.ToString("N0") ₫
                                </td>

                                <td class="text-success fw-bold">
                                    @total.ToString("N0") ₫
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6"
                                class="text-center py-5 text-muted">

                                <i class="fas fa-receipt fs-1 d-block mb-3"></i>

                                Chưa có dữ liệu chi tiết đơn hàng

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<style>

    body {
        background: #f8f9fc;
    }

    .detail-card {
        border-radius: 18px;
        overflow: hidden;
        background: white;
    }

    .header-custom {
        background: linear-gradient(135deg, #36b9cc, #258391);
        padding: 1.5rem 2rem;
    }

    .custom-table thead th {
        background: #f8f9fc;
        color: #36b9cc;
        text-transform: uppercase;
        font-size: 13px;
        border-top: none;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
    }

        .custom-table tbody tr:hover {
            background: #f8feff;
            transform: scale(1.002);
        }

</style>